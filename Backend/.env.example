# Gemini API settings
GEMINI_API_KEY=your_gemini_api_key

# Optional settings (defaults shown)
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_SECONDS=30
GEMINI_PARALLELISM=5

# refer_dictionary_v1 settings
# GeminiAPIのバッチ数と意味の生成数
REFER_DICTIONARY_V1_GROUP_SIZE=10
REFER_DICTIONARY_V1_GENERATE_MAX_SENSE=3
GEMINI_TIMEOUT_SECONDS=5

# DB が空または未接続のときだけ使う開発用フォールバック。
# IDF_JSON_PATH=data/idf/ja_wiki_idf.json

# この IDF 以上の語だけ起動時に読み込む（未設定＝DB/JSON は実質全件）。
# TERM_IDF_LOAD_MIN_VALUE=3.0

# CockroachDB settings
DATABASE_URL=db_connection_string 
DEV_DATABASE_URL=dev_db_connection_string
